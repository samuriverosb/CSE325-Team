@page "/categories"
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using SelfRelianceFinanceTracker.Web.Data
@using SelfRelianceFinanceTracker.Web.Models
@using SelfRelianceFinanceTracker.Web.Services

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject ICategoryService CategoryService

<PageTitle>Categories</PageTitle>

<main class="container py-4">

    <div class="mb-4">
        <h1 class="h3 mb-1">Categories</h1>
        <p class="text-muted">Manage your income and expense categories.</p>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Add Category</h5>

            <EditForm Model="newCategory" OnValidSubmit="AddCategory" FormName="AddCategoryForm" method="post">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger mb-3" role="alert" />

                <div class="mb-3">
                    <label for="catName" class="form-label">Category Name *</label>
                    <InputText id="catName" @bind-Value="newCategory.Name" class="form-control" />
                    <ValidationMessage For="() => newCategory.Name" class="text-danger" />
                </div>

                <div class="mb-3">
                    <label for="monthlyLimit" class="form-label">Monthly Limit</label>
                    <InputNumber id="monthlyLimit" @bind-Value="newCategory.MonthlyLimit" class="form-control" />
                    <div class="form-text">Optional spending limit for this category.</div>
                    <ValidationMessage For="() => newCategory.MonthlyLimit" class="text-danger" />
                </div>

                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary" aria-label="Add Category">Add Category</button>
                </div>
            </EditForm>
        </div>
    </div>

    @if (categories is null)
    {
        <p role="status">Loading categories...</p>
    }
    else if (categories.Count == 0)
    {
        <p role="status">No categories found yet.</p>
    }
    else
    {
        <div class="card">
            <div class="card-body">
                <table class="table table-striped table-hover align-middle">
                    <caption class="visually-hidden">Budget categories with monthly limits and management actions.</caption>
                    <thead>
                        <tr>
                            <th scope="col">Name</th>
                            <th scope="col">Monthly Limit</th>
                            <th scope="col">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var category in categories)
                        {
                            <tr>
                                @if (editingCategoryId == category.Id)
                                {
                                    <td>
                                        <InputText @bind-Value="editCategory.Name" class="form-control" />
                                    </td>
            
                                    <td>
                                        <InputNumber @bind-Value="editCategory.MonthlyLimit" class="form-control" />
                                    </td>
            
                                    <td>
                                        <button type="button" class="btn btn-success btn-sm me-2" @onclick="SaveEdit"
                                                aria-label="Save edit">Save</button>
                                        <button type="button" class="btn btn-secondary btn-sm" @onclick="CancelEdit"
                                                aria-label="Cancel edit">Cancel</button>
                                    </td>
                                }
                                else
                                {
                                    <td>@category.Name</td>
                                    <td>$@category.MonthlyLimit.ToString("N2")</td>
            
                                    <td>
                                        <button type="button" class="btn btn-primary btn-sm me-2" @onclick="() => StartEdit(category)"
                                                aria-label="Edit category">
                                            Edit
                                        </button>
            
                                        <button type="button" class="btn btn-danger btn-sm" @onclick="() => DeleteCategory(category.Id)"
                                                aria-label="Delete category">
                                            Delete
                                        </button>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</main>

@code {
    private IReadOnlyList<Category>? categories;

    private Category newCategory = new();

    private int? editingCategoryId = null;
    private Category editCategory = new();

    private async Task AddCategory()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        if (user is null) return;

        newCategory.UserId = user.Id;

        await CategoryService.CreateAsync(newCategory);

        categories = await CategoryService.GetForUserAsync(user.Id);

        newCategory = new Category();
    }

    private async Task DeleteCategory(int id)
    {
        await CategoryService.DeleteAsync(id);

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        if (user is null) return;

        categories = await CategoryService.GetForUserAsync(user.Id);
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);
        if (user is null)
        {
            categories = [];
            return;
        }

        categories = await CategoryService.GetForUserAsync(user.Id);
    }

    private void StartEdit(Category category)
    {
        editingCategoryId = category.Id;

        editCategory = new Category
        {
            Id = category.Id,
            Name = category.Name,
            MonthlyLimit = category.MonthlyLimit,
            UserId = category.UserId
        };
    }

    private async Task SaveEdit()
    {
        await CategoryService.UpdateAsync(editCategory);

        editingCategoryId = null;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        if (user is null) return;

        categories = await CategoryService.GetForUserAsync(user.Id);
    }

    private void CancelEdit()
    {
        editingCategoryId = null;
    }
}
