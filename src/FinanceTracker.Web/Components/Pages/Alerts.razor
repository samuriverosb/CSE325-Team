@page "/alerts"
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using SelfRelianceFinanceTracker.Web.Data
@using SelfRelianceFinanceTracker.Web.Models
@using SelfRelianceFinanceTracker.Web.Services

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject IAlertService AlertService
@inject NavigationManager NavigationManager

<PageTitle>Alerts</PageTitle>

<main class="container py-4">

    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Alerts</h1>
            <p class="text-muted mb-0">Budget and savings reminders that help you react before problems grow.</p>
        </div>

        <button type="button" class="btn btn-outline-primary" @onclick="@(() => NavigationManager.NavigateTo("/reports"))">
            Open Reports
        </button>
    </div>

    @if (alerts is null)
    {
        <p role="status">Loading alerts...</p>
    }
    else
    {
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h2 class="h6 text-muted">High Priority</h2>
                        <p class="h4 mb-0 text-danger">@alerts.Count(alert => alert.Severity == AlertSeverity.Danger)</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h2 class="h6 text-muted">Warnings</h2>
                        <p class="h4 mb-0 text-warning">@alerts.Count(alert => alert.Severity == AlertSeverity.Warning)</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h2 class="h6 text-muted">Info</h2>
                        <p class="h4 mb-0 text-info">@alerts.Count(alert => alert.Severity == AlertSeverity.Info)</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3">
            @foreach (var alert in alerts)
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body d-flex flex-column flex-lg-row justify-content-between gap-3">
                            <div>
                                <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                                    <span class="badge @alert.BadgeClass">@alert.Area</span>
                                    <h2 class="h5 mb-0">@alert.Title</h2>
                                </div>

                                <p class="mb-1">@alert.Message</p>
                                <small class="text-muted">Suggested action: @alert.SuggestedAction</small>
                            </div>

                            <div class="d-flex align-items-start">
                                <button type="button" class="btn btn-outline-secondary" @onclick="@(() => NavigationManager.NavigateTo(alert.SuggestedRoute))">
                                    @alert.SuggestedAction
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</main>

@code {
    private IReadOnlyList<AlertNotification>? alerts;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        if (user is null)
        {
            alerts = [];
            return;
        }

        alerts = await AlertService.GetAlertsForUserAsync(user.Id);
    }
}
