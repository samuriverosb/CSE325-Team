@page "/savings-goals"
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using SelfRelianceFinanceTracker.Web.Data
@using SelfRelianceFinanceTracker.Web.Models
@using SelfRelianceFinanceTracker.Web.Services

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject ISavingsGoalService SavingsGoalService

<PageTitle>Savings Goals</PageTitle>

<main class="container py-4">

    <div class="mb-4">
        <h1 class="h3 mb-1">Savings Goals</h1>
        <p class="text-muted">Manage your savings goals.</p>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Add Savings Goal</h5>

            <EditForm Model="newGoal" OnValidSubmit="AddGoal" FormName="AddGoalForm">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger mb-3" />

                <div class="mb-3">
                    <label for="goalName" class="form-label">Goal Name *</label>
                    <InputText id="goalName" @bind-Value="newGoal.GoalName" class="form-control" />
                </div>

                <div class="mb-3">
                    <label for="targetAmount" class="form-label">Target Amount *</label>
                    <InputNumber id="targetAmount" @bind-Value="newGoal.TargetAmount" class="form-control" />
                </div>

                <div class="mb-3">
                    <label for="currentAmount" class="form-label">Current Amount</label>
                    <InputNumber id="currentAmount" @bind-Value="newGoal.CurrentAmount" class="form-control" />
                    <div class="form-text">How much you have saved so far.</div>
                </div>

                <div class="mb-3">
                    <label for="deadline" class="form-label">Deadline *</label>
                    <InputDate id="deadline" @bind-Value="newGoal.Deadline" class="form-control" />
                </div>

                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary" aria-label="Add goal">Add Goal</button>
                </div>
            </EditForm>
        </div>
    </div>

    @if (goals is null)
    {
        <p>Loading savings goals...</p>
    }
    else if (goals.Count == 0)
    {
        <p>No savings goals found yet.</p>
    }
    else
    {
        <div class="card">
            <div class="card-body">
                <table class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th scope="col">Goal</th>
                            <th scope="col">Current</th>
                            <th scope="col">Target</th>
                            <th scope="col">Deadline</th>
                            <th scope="col">Progress</th>
                            <th scope="col">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var goal in goals)
                        {
                            var progress = goal.TargetAmount <= 0 ? 0 : Math.Min(100, (goal.CurrentAmount / goal.TargetAmount) * 100);

                            <tr>
                                @if (editingGoalId == goal.Id)
                                {
                                    <td>
                                        <InputText @bind-Value="editGoal.GoalName" class="form-control" />
                                    </td>
                                    <td>
                                        <InputNumber @bind-Value="editGoal.CurrentAmount" class="form-control" />
                                    </td>
                                    <td>
                                        <InputNumber @bind-Value="editGoal.TargetAmount" class="form-control" />
                                    </td>
                                    <td>
                                        <InputDate @bind-Value="editGoal.Deadline" class="form-control" />
                                    </td>
                                    <td>-</td>

                                    <td>
                                        <button type="submit" class="btn btn-success btn-sm me-2" @onclick="SaveEdit" aria-label="Save edit">Save</button>
                                        <button type="button" class="btn btn-secondary btn-sm" @onclick="CancelEdit" aria-label="Cancel edit">Cancel</button>
                                    </td>
                                }
                                else
                                {
                                    <td>@goal.GoalName</td>
                                    <td>$@goal.CurrentAmount.ToString("N2")</td>
                                    <td>$@goal.TargetAmount.ToString("N2")</td>
                                    <td>@goal.Deadline.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        <div class="progress">
                                            <div class="progress-bar @(progress switch {
                                                    >= 100 => "bg-success",
                                                    >= 75 => "bg-info",
                                                    >= 50 => "bg-warning",
                                                    _ => "bg-danger"
                                                })"
                                                    role="progressbar"
                                                    aria-valuenow="@progress"
                                                    aria-valuemin="0"
                                                    aria-valuemax="100"
                                                    style="width: @(progress.ToString(System.Globalization.CultureInfo.InvariantCulture) + "%")">
                                                @progress.ToString("N0")%
                                            </div>
                                        </div>
                                        <small>
                                            Remaining: $@((goal.TargetAmount - goal.CurrentAmount).ToString("N2"))
                                        </small>
                                    </td>

                                    <td>
                                        <button type="button" class="btn btn-primary btn-sm me-2" @onclick="() => StartEdit(goal)" aria-label="Edit goal">Edit</button>
                                        <button type="button" class="btn btn-danger btn-sm" @onclick="() => DeleteGoal(goal.Id)" aria-label="Delete goal">Delete</button>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

</main>

@code {
    private IReadOnlyList<SavingsGoal>? goals;

    private SavingsGoal newGoal = new()
    {
        Deadline = DateTime.Now.Date.AddMonths(6)
    };

    private int? editingGoalId = null;
    private SavingsGoal editGoal = new();

    private async Task AddGoal()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        if (user is null) return;

        newGoal.UserId = user.Id;

        await SavingsGoalService.CreateAsync(newGoal);

        goals = await SavingsGoalService.GetForUserAsync(user.Id);

        newGoal = new SavingsGoal
        {
            Deadline = DateTime.Now.Date.AddMonths(6)
        };
    }

    private void StartEdit(SavingsGoal goal)
    {
        editingGoalId = goal.Id;

        editGoal = new SavingsGoal
        {
            Id = goal.Id,
            GoalName = goal.GoalName,
            TargetAmount = goal.TargetAmount,
            CurrentAmount = goal.CurrentAmount,
            Deadline = goal.Deadline,
            UserId = goal.UserId
        };
    }

    private async Task SaveEdit()
    {
        await SavingsGoalService.UpdateAsync(editGoal);

        editingGoalId = null;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        if (user is null) return;

        goals = await SavingsGoalService.GetForUserAsync(user.Id);
    }

    private void CancelEdit()
    {
        editingGoalId = null;
    }

    private async Task DeleteGoal(int id)
    {
        await SavingsGoalService.DeleteAsync(id);

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        if (user is null) return;

        goals = await SavingsGoalService.GetForUserAsync(user.Id);
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);
        if (user is null)
        {
            goals = [];
            return;
        }

        goals = await SavingsGoalService.GetForUserAsync(user.Id);
    }
}
